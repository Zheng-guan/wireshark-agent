# ===== Wireshark 智能助手 配置文件 =====
# 复制本文件为 .env 并填入真实值

# ---- Tshark / Wireshark 路径 ----
# tshark.exe 的完整路径。留空则自动探测 Program Files / 各盘符根目录。
# 示例：E:\Wireshark\tshark.exe
TSHARK_PATH=E:\Wireshark\tshark.exe

# ---- 智谱 GLM API Key ----
# 在 https://open.bigmodel.cn/ 申请
ZHIPUAI_API_KEY=

# ---- LLM 模型配置 ----
# 模型名称：glm-4.7 / glm-4.6 / glm-4-flash 等
LLM_MODEL=glm-4.7
# 采样温度（0-1，网络分析建议较低温度）
LLM_TEMPERATURE=0.2
# 深度思考模式：disabled(关闭,响应快,默认) / enabled(开启,推理强但慢)
LLM_THINKING=disabled
# 最大输出 token（留空使用默认）
# LLM_MAX_TOKENS=4096

# ---- 抓包默认参数 ----
DEFAULT_CAPTURE_DURATION=10
DEFAULT_PACKET_LIMIT=5000

# ---- 日志级别 ----
LOG_LEVEL=INFO
